function navTo(id){const el=document.getElementById(id);if(el)el.scrollIntoView({behavior:'smooth',block:'start'});}
let lang='en';
function setLang(l){lang=l;document.querySelectorAll('.lb').forEach((b,i)=>b.classList.toggle('active',(i===0&&l==='en')||(i===1&&l==='de')));render();}

function tlHTML(items){
  return`<div class="tl">${items.map(e=>`<div class="tli">
    <div class="tl-role">${e.r}</div>
    <div class="tl-org">${e.o}</div>
    <div class="tl-period">${e.p}</div>
    ${e.d?`<div class="tl-desc">${e.d}</div>`:''}
  </div>`).join('')}</div>`;
}

function render(){
  const d=C[lang];
  document.getElementById('nl').innerHTML=d.nav.map((n,i)=>`<li><a href="#" onclick="event.preventDefault();event.stopPropagation();navTo('${d.ids[i]}');">${n}</a></li>`).join('');
  document.getElementById('h-sub').textContent=d.sub;
  document.getElementById('h-inst').textContent=d.inst;
  document.getElementById('about-h').textContent=d.about.h;
  document.getElementById('about-txt').textContent=d.about.t;
  document.getElementById('res-h').textContent=d.res.h;
  const r=d.res;
  document.getElementById('res-c').innerHTML=
    `<div class="card"><div class="card-lbl">${r.diss.lbl}</div><div class="card-title">${r.diss.title}</div><div class="card-inst">${r.diss.inst}</div><ul class="focus-tags">${r.diss.focus.map(f=>`<li>${f}</li>`).join('')}</ul></div>`+
    r.teach.map(t=>`<div class="card"><div class="card-lbl">${t.lbl}</div><div class="card-title">${t.title}</div><div class="card-inst">${t.inst}</div><p style="font-size:0.85rem;color:var(--txtl)">${t.note}</p></div>`).join('');
  document.getElementById('cv-h').textContent=d.cv.h;
  const cv=d.cv;
  document.getElementById('cv-c').innerHTML=
    `<p class="sublbl">${cv.el}</p>${tlHTML(cv.exp)}`+
    `<p class="sublbl">${cv.edu}</p>${tlHTML(cv.edu)}`+
    `<p class="sublbl">${cv.fw}</p>${tlHTML(cv.fur)}`;
  document.getElementById('pub-h').textContent=d.pub.h;
  const p=d.pub;
  document.getElementById('pub-c').innerHTML=
    `<p class="sublbl">${p.pl}</p>${p.pubs.map(x=>`<div class="pub">${x}</div>`).join('')}`+
    `<p class="sublbl">${p.cl}</p>${p.conf.map(x=>`<div class="conf-item">${x}</div>`).join('')}`;
  document.getElementById('med-h').textContent=d.med.h;
  const m=d.med;
  document.getElementById('med-c').innerHTML=
    `<div class="card"><div class="card-lbl">${m.rl}</div><div class="card-inst" style="margin-bottom:0.6rem">${m.ro}</div><ul style="padding-left:1.1rem">${m.ri.map(i=>`<li style="font-size:0.88rem;color:var(--txtl);margin-bottom:0.25rem">${i}</li>`).join('')}</ul></div>`+
    `<div class="card"><div class="card-lbl">${m.cl}</div><p style="font-size:0.88rem;color:var(--txtl)">${m.ct}</p></div>`;
  document.getElementById('sk-h').textContent=d.sk.h;
  const s=d.sk;
  document.getElementById('sk-c').innerHTML=`<div class="skills-grid">
    <div class="sc"><div class="sc-title">${s.ll}</div><table class="lt">${s.langs.map(([a,b])=>`<tr><td><strong>${a}</strong></td><td>${b}</td></tr>`).join('')}</table></div>
