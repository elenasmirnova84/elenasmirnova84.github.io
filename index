// Photo
async function loadPhoto(){
  try{
    const r=await window.storage.get('profile-photo');
    if(r&&r.value){setPhoto(r.value);document.getElementById('ph-upload-btn').style.display='none';}
  }catch(e){}
}
function setPhoto(src){
  const c=document.getElementById('ph-container');
  c.innerHTML=`<img class="ph" src="${src}" alt="Elena Smirnova" onerror="this.parentNode.innerHTML='<div class=\\'ph-fb\\'>ES</div>'">`;
}
document.getElementById('ph-input').addEventListener('change',function(e){
  const f=e.target.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=async function(ev){
    const data=ev.target.result;
    setPhoto(data);
    document.getElementById('ph-upload-btn').style.display='none';
    try{await window.storage.set('profile-photo',data);}catch(err){}
  };
  reader.readAsDataURL(f);
});
loadPhoto();
</script>
